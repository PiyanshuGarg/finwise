# FinWise — Environment Variables Example
# Copy this file to .env and fill in your actual values
# The prototype works WITHOUT any of these — they are only needed for production

# Anthropic Claude API (AI Advisor chat)
# Get your key at: https://console.anthropic.com
CLAUDE_API_KEY=your_anthropic_api_key_here

# Firebase (Authentication + Database)
# Get your keys at: https://console.firebase.google.com
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_APP_ID=your_app_id_here

# NSE Market Data API (Live stock prices)
NSE_API_KEY=your_nse_api_key_here

# Insurance Policy API
INSURANCE_API_KEY=your_insurance_api_key_here

# UPI Stack (Payment tracking)
UPI_API_KEY=your_upi_api_key_here
